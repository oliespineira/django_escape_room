
# AI features (https://openrouter.ai — OpenAI-compatible, free models available)
OPENROUTER_API_KEY=
# Optional (defaults are fine for Qwen :free, but 429s are common on shared free routes):
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
# If you hit HTTP 429, wait a few minutes or try another :free model from openrouter.ai/models, e.g.:
# OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free
# OPENROUTER_HTTP_REFERER=http://127.0.0.1:8000
# Retries (app backs off between attempts when OpenRouter returns 429):
# OPENROUTER_STREAM_RETRIES=4
# OPENROUTER_429_BACKOFF=2.5
# If you prefer OpenAI.com instead of OpenRouter, use OPENAI_API_KEY and do not set OPENROUTER_API_KEY.
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o
